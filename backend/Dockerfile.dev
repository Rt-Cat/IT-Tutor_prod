# Development Dockerfile for Express.js Backend
FROM node:20-alpine

WORKDIR /usr/src/app

# Копіюємо маніфести пакетів
COPY package*.json ./

# Встановлюємо ВСІ залежності (включно з nodemon з devDependencies)
RUN npm install

# Копіюємо решту вихідного коду
COPY . .

# Відкриваємо порт
EXPOSE 5000

# Змінні середовища для розробки
ENV PORT=5000
ENV HOST=0.0.0.0
ENV NODE_ENV=development

# Запускаємо через nodemon
CMD ["npm", "run", "dev"]