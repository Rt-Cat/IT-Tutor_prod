<%- include('../partials/header') %>
<div class="dashboard-wrapper">
    <h3>Управління практичними завданнями (Tasks)</h3>
    <p class="subtitle">Створення умов, вимог до складності та перевірка завдань ШІ-Ментором.</p>
    
    <% if (typeof userRole !== 'undefined' && userRole === 'instructor') { %>
        <div style="background: var(--bg-card); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 2rem;">
            <h5>Нове практичне завдання</h5>
            <form action="/instructor/tasks/add" method="POST" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                
                <div style="grid-column: span 2;">
                    <label>Оберіть курс:</label>
                    <select name="courseId" required>
                        <option value="1">Вступ до ООП в Python</option>
                        </select>
                </div>

                <div>
                    <label>Назва завдання:</label>
                    <input type="text" name="title" placeholder="Реалізація класу Car" required>
                </div>
                
                <div>
                    <label>Складність (Difficulty):</label>
                    <select name="difficulty">
                        <option value="easy">Easy (Легко)</option>
                        <option value="medium">Medium (Середньо)</option>
                        <option value="hard">Hard (Складно)</option>
                    </select>
                </div>

                <div>
                    <label>Орієнтовний час (хв):</label>
                    <input type="number" name="estimatedMinutes" placeholder="Напр. 30" required>
                </div>

                <div style="display: flex; align-items: center; gap: 10px; padding-top: 1.5rem;">
                    <input type="checkbox" name="isFree" value="1" style="width: auto; margin: 0;">
                    <label style="margin: 0;">Доступно в безкоштовному плані (FREE)</label>
                </div>

                <div style="grid-column: span 2;">
                    <label>Умова завдання (Task Description):</label>
                    <textarea name="taskDescription" rows="4" placeholder="Опишіть, що саме має написати студент, які методи реалізувати та які дані повертати..." required></textarea>
                </div>

                <button type="submit" style="grid-column: span 2;">Додати завдання та відправити на перевірку</button>
            </form>
        </div>
    <% } %>

    <h4>База практичних завдань</h4>
    <table class="styled-table" style="width: 100%; border-collapse: collapse; margin-top: 1rem;">
        <thead>
            <tr style="background-color: var(--bg-main); color: var(--text-muted); text-align: left;">
                <th style="padding: 1rem; border-bottom: 1px solid var(--border);">Завдання</th>
                <th style="padding: 1rem; border-bottom: 1px solid var(--border);">Складність</th>
                <th style="padding: 1rem; border-bottom: 1px solid var(--border);">Доступ</th>
                <th style="padding: 1rem; border-bottom: 1px solid var(--border);">Статус</th>
                <th style="padding: 1rem; border-bottom: 1px solid var(--border);">Дії</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td style="padding: 1rem; border-bottom: 1px solid var(--border);">
                    <strong>Реалізація класу Car</strong><br>
                    <small style="color: var(--text-muted);">Курс: Вступ до ООП в Python</small>
                </td>
                <td style="padding: 1rem; border-bottom: 1px solid var(--border);">
                    <span style="background: var(--bg-input); padding: 3px 8px; border-radius: 4px;">easy</span>
                </td>
                <td style="padding: 1rem; border-bottom: 1px solid var(--border);">
                    <span style="color: var(--success);">Free</span>
                </td>
                <td style="padding: 1rem; border-bottom: 1px solid var(--border);">
                    <span style="color: #fbbf24;">Очікує модерації</span>
                </td>
                <td style="padding: 1rem; border-bottom: 1px solid var(--border);">
                    <% if (typeof userRole !== 'undefined' && userRole === 'moderator') { %>
                        <button style="background: var(--success); padding: 5px 10px; font-size: 0.85rem;">Затвердити</button>
                        <button style="background: var(--error); padding: 5px 10px; font-size: 0.85rem;">Відхилити</button>
                    <% } else { %>
                        <button style="background: #4b5563; padding: 5px 10px; font-size: 0.85rem;">Редагувати</button>
                    <% } %>
                </td>
            </tr>
        </tbody>
    </table>
</div>
<%- include('../partials/footer') %>