<%- include('../partials/header') %>
<div class="dashboard-wrapper">
    <h3>Кабінет студента</h3>
    <p class="subtitle">Ваша персональна статистика та глобальний рейтинг платформи.</p>
    
    <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem; margin-top: 2rem;">
        
        <div>
            <h5>Моя активність (Пройдені завдання)</h5>
            <table class="styled-table">
                <thead>
                    <tr>
                        <th>Завдання / Контекст</th>
                        <th>Складність</th>
                        <th>Статус</th>
                        <th>Бал</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (progress && progress.length > 0) { %>
                        <% progress.forEach(item => { %>
                            <tr>
                                <td>
                                    <strong><%= item.TASKTITLE %></strong><br>
                                    <small style="color: var(--text-muted);"><%= item.TECHNAME %> → <%= item.COURSETITLE %></small>
                                </td>
                                <td><span style="background: var(--bg-input); padding: 3px 8px; border-radius: 4px;"><%= item.DIFFICULTY %></span></td>
                                <td>
                                    <% if (item.STATUS === 'completed') { %> <span style="color: var(--success);">Виконано</span>
                                    <% } else if (item.STATUS === 'failed') { %> <span style="color: var(--error);">Помилка</span>
                                    <% } else { %> <span style="color: #fbbf24;">В процесі</span> <% } %>
                                </td>
                                <td><strong><%= item.SCORE %></strong>/100</td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="4" style="text-align: center; color: var(--text-muted);">Ви ще не виконали жодного завдання.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <div style="background: var(--bg-card); border: 1px solid var(--border); padding: 1.5rem; border-radius: 8px; height: fit-content;">
            <h5 style="color: var(--accent); margin-top: 0;">🏆 Топ Студентів (Scoreboard)</h5>
            <div style="display: flex; flex-direction: column; gap: 1rem; margin-top: 1rem;">
                <% if (scoreboard && scoreboard.length > 0) { %>
                    <% scoreboard.forEach((user, index) => { %>
                        <div style="display: flex; justify-content: space-between; align-items: center; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                            <div>
                                <span style="color: var(--text-muted); margin-right: 10px;">#<%= index + 1 %></span>
                                <strong><%= user.EMAIL.split('@')[0] %></strong> </div>
                            <div style="color: var(--success); font-weight: 600;"><%= user.TOTALSCORE %> балів</div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="color: var(--text-muted); text-align: center;">Рейтинг поки порожній.</p>
                <% } %>
            </div>
        </div>

    </div>
</div>
<%- include('../partials/footer') %>