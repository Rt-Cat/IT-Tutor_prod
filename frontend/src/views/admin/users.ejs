<%- include('../partials/header') %>
<div class="dashboard-wrapper">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <div>
            <h3>Управління Користувачами</h3>
            <p class="subtitle">Перегляд, фільтрація, реєстрація та блокування акаунтів.</p>
        </div>
        <button onclick="document.getElementById('addUserModal').style.display='flex'" style="padding: 10px 20px; background: #10b981; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer;">
            + Додати користувача
        </button>
    </div>
    <form action="/admin/users" method="GET" style="margin-bottom: 2rem; display: flex; flex-direction: row; gap: 1rem; align-items: center; justify-content: flex-start; background: var(--bg-card); padding: 1rem; border-radius: 8px; border: 1px solid var(--border); flex-wrap: nowrap; overflow-x: auto;">
        
        <input type="text" name="search" placeholder="Пошук за Email..." value="<%= query.search || '' %>" style="padding: 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-input); color: white; min-width: 250px; flex-grow: 1;">
        
        <select name="role" style="padding: 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-input); color: white; min-width: 150px; cursor: pointer;">
            <option value="">Всі ролі</option>
            <option value="student" <%= query.role === 'student' ? 'selected' : '' %>>Студенти</option>
            <option value="instructor" <%= query.role === 'instructor' ? 'selected' : '' %>>Інструктори</option>
            <option value="moderator" <%= query.role === 'moderator' ? 'selected' : '' %>>Модератори</option>
            <option value="admin" <%= query.role === 'admin' ? 'selected' : '' %>>Адміністратори</option>
        </select>

        <select name="isActive" style="padding: 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-input); color: white; min-width: 150px; cursor: pointer;">
            <option value="">Всі статуси</option>
            <option value="1" <%= query.isActive === '1' ? 'selected' : '' %>>Активні</option>
            <option value="0" <%= query.isActive === '0' ? 'selected' : '' %>>Заблоковані</option>
        </select>

        <button type="submit" style="padding: 10px 20px; border-radius: 6px; background: #3b82f6; color: white; border: none; cursor: pointer; font-weight: bold; white-space: nowrap;">Застосувати</button>
        <a href="/admin/users" style="padding: 10px 20px; color: var(--text-muted); text-decoration: none; border: 1px solid var(--border); border-radius: 6px; background: transparent; transition: 0.2s; white-space: nowrap;">Скинути</a>
        
    </form>

    <table class="styled-table" style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead>
            <tr style="border-bottom: 1px solid var(--border); color: var(--text-muted);">
                <th style="padding: 1rem;">UserID</th>
                <th style="padding: 1rem;">Електронна пошта</th>
                <th style="padding: 1rem;">Роль безпеки</th>
                <th style="padding: 1rem;">Статус акаунту</th>
                <th style="padding: 1rem;">Дії</th>
            </tr>
        </thead>
        <tbody>
            <% if (users && users.length > 0) { %>
                <% users.forEach(u => { %>
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 1rem;">#<%= u.USERID %></td>
                        <td style="padding: 1rem; font-weight: bold;"><%= u.EMAIL %></td>
                        <td style="padding: 1rem;">
                            <span style="background: var(--bg-input); padding: 4px 10px; border-radius: 4px; font-size: 0.9rem;"><%= u.ROLE %></span>
                        </td>
                        <td style="padding: 1rem;">
                            <% if (u.ISACTIVE === 1) { %>
                                <span style="color: #10b981;">✅ Активний (Active)</span>
                            <% } else { %>
                                <span style="color: #ef4444;">🛑 Заблокований</span>
                            <% } %>
                        </td>
                        <td style="padding: 1rem;">
                            <form action="/admin/users/toggle/<%= u.USERID %>" method="POST" style="margin: 0;">
                                <input type="hidden" name="isActive" value="<%= u.ISACTIVE === 1 ? 0 : 1 %>">
                                <button type="submit" style="background: <%= u.ISACTIVE === 1 ? '#ef4444' : '#10b981' %>; padding: 5px 10px; font-size: 0.85rem; border: none; border-radius: 4px; color: white; cursor: pointer;">
                                    <%= u.ISACTIVE === 1 ? 'Заблокувати' : 'Активувати' %>
                                </button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            <% } else { %>
                <tr><td colspan="5" style="text-align: center; padding: 2rem;">Користувачів не знайдено</td></tr>
            <% } %>
        </tbody>
    </table>
</div>
<div id="addUserModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); align-items: center; justify-content: center; z-index: 1000;">
        <div style="background: var(--bg-card); padding: 2rem; border-radius: 8px; width: 400px; border: 1px solid var(--border); box-shadow: 0 10px 25px rgba(0,0,0,0.5);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h4 style="margin: 0;">Реєстрація користувача</h4>
                <button onclick="document.getElementById('addUserModal').style.display='none'" style="background: transparent; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer;">&times;</button>
            </div>
            
            <form action="/admin/users/register" method="POST" style="display: flex; flex-direction: column; gap: 1rem;">
                <div>
                    <label style="display: block; margin-bottom: 5px; color: var(--text-muted);">Електронна пошта</label>
                    <input type="email" name="email" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid var(--border); background: var(--bg-input); color: white;">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 5px; color: var(--text-muted);">Тимчасовий пароль</label>
                    <input type="password" name="password" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid var(--border); background: var(--bg-input); color: white;">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 5px; color: var(--text-muted);">Роль в системі</label>
                    <select name="role" required style="width: 100%; padding: 10px; border-radius: 4px; border: 1px solid var(--border); background: var(--bg-input); color: white;">
                        <option value="student">Студент</option>
                        <option value="instructor">Інструктор</option>
                        <option value="moderator">Модератор</option>
                        <option value="admin">Адміністратор</option>
                    </select>
                </div>
                <button type="submit" style="margin-top: 1rem; padding: 12px; background: #3b82f6; color: white; border: none; border-radius: 6px; font-weight: bold; cursor: pointer;">
                    Створити акаунт
                </button>
            </form>
        </div>
    </div>
<%- include('../partials/footer') %>